    <string name="settings_unlock_description">Абонирайте се за една година, за да продължите да използвате SweetSpot.</string>

    <!-- Paywall -->
    <string name="paywall_title">Пробният период приключи</string>
    <string name="paywall_description">SweetSpot намира най-евтиното време за работа на вашите уреди, като използва цени на електроенергия в реално време в 30 европейски държави. Абонирайте се, за да продължите да откривате най-евтиното време за вашите уреди.</string>
    <string name="paywall_unlock">Абонирай се за SweetSpot</string>
