    <!-- Paywall -->
    <string name="paywall_title">Вашиот пробен период заврши</string>
    <string name="paywall_description">SweetSpot го наоѓа најевтиното време за работа на вашите уреди користејќи цени на електрична енергија во реално време во 30 европски земји. Претплатете се за да продолжите да го наоѓате најевтиното време за вашите уреди.</string>
    <string name="paywall_unlock">Претплати се на SweetSpot</string>
