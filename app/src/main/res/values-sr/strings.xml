    <!-- Stats -->
    <string name="settings_stats_title">Дели API статистике</string>
    <string name="settings_stats_description">Помозите побољшању поузданости извора података дељењем анонимних статистика успеха/неуспеха API-ја. Не прикупљају се лични подаци.</string>
    <string name="stats_prompt_title">Помозите да побољшамо SweetSpot?</string>
    <string name="stats_prompt_message">Поделите анонимне API статистике да бисте помогли побољшању поузданости извора података. Деле се само бројеви успешних/неуспешних захтева по извору — без личних података. Ово можете да промените у било ком тренутку у Подешавањима.</string>
    <string name="stats_prompt_enable">Укључи</string>
    <string name="stats_prompt_dismiss">Не, хвала</string>

