<?xml version="1.0" encoding="utf-8"?>
<!-- Cloud backup / device transfer rules for API 31+. Only back up user settings. -->
<data-extraction-rules>
    <cloud-backup>
        <include domain="sharedpref" path="sweetspot_settings.xml" />
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="sweetspot_settings.xml" />
    </device-transfer>
</data-extraction-rules>
